---
import CaseStudyPage from '../../views/CaseStudyPage.astro';
import { getCaseStudy } from '../../data/site';
import { caseStudyPathSegments } from '../../data/routes';

export function getStaticPaths() {
  return Object.entries(caseStudyPathSegments).map(([studySlug, segment]) => ({
    params: { slug: segment },
    props: { studySlug },
  }));
}

interface Props {
  studySlug: string;
}

const { studySlug } = Astro.props;
const study = getCaseStudy(studySlug);
if (!study) throw new Error(`Case study ${studySlug} not found`);
---

<CaseStudyPage lang="es" study={study} />
