---
import Base from '../../layouts/Base.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { projects } from '../../data/projects';
import { useTranslations } from '../../i18n/ui';

const lang = 'en';
const t = useTranslations(lang);
---

<Base title={`${t.work.title} — Portfolio`} description={t.work.subtitle} lang={lang} currentPath="/en/work">
  <section class="section">
    <div class="container">
      <h1 class="section-title">{t.work.title}</h1>
      <p class="section-subtitle">{t.work.subtitle}</p>
      <div class="project-grid">
        {projects.map((project) => <ProjectCard project={project} lang={lang} />)}
      </div>
    </div>
  </section>
</Base>

<style>
  .project-grid { display: grid; gap: 1.5rem; }
  @media (min-width: 768px) { .project-grid { grid-template-columns: repeat(2, 1fr); } }
</style>
