---
import Base from '../../../layouts/Base.astro';
import { projects, getProject } from '../../../data/projects';
import { useTranslations } from '../../../i18n/ui';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
  }));
}

const { slug } = Astro.params;
const project = getProject(slug!);
if (!project) return Astro.redirect('/en/work');

const lang = 'en';
const t = useTranslations(lang);
---

<Base
  title={`${project.title[lang]} — Portfolio`}
  description={project.summary[lang]}
  lang={lang}
  currentPath={`/en/projects/${project.slug}`}
>
  <article class="case-study">
    <section class="case-hero section">
      <div class="container">
        <a href="/en/work" class="back-link">← {t.project.back}</a>
        <p class="case-meta">{project.client} · {project.year}</p>
        <h1>{project.title[lang]}</h1>
        <p class="case-summary">{project.summary[lang]}</p>
        <dl class="case-details">
          <div><dt>{t.project.role}</dt><dd>{project.role[lang]}</dd></div>
          <div><dt>{t.project.client}</dt><dd>{project.client}</dd></div>
          <div><dt>{t.project.year}</dt><dd>{project.year}</dd></div>
        </dl>
      </div>
    </section>
    <section class="case-cover"><div class="container"><img src={project.cover} alt={project.title[lang]} /></div></section>
    <section class="section">
      <div class="container case-content">
        <section><h2>{t.project.challenge}</h2><p>{project.challenge[lang]}</p></section>
        <section><h2>{t.project.process}</h2><p>{project.process[lang]}</p></section>
        <section><h2>{t.project.outcome}</h2><p>{project.outcome[lang]}</p></section>
      </div>
    </section>
    <section class="section gallery-section">
      <div class="container gallery">
        {project.gallery.map((src) => <img src={src} alt="" loading="lazy" />)}
      </div>
    </section>
  </article>
</Base>

<style>
  .case-hero { background: linear-gradient(180deg, var(--color-hero-bg), white); padding-bottom: 2rem; }
  .back-link { display: inline-block; margin-bottom: 1.5rem; color: var(--color-accent); font-weight: 600; }
  .case-meta { margin: 0 0 0.75rem; color: var(--color-accent); font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; font-size: 0.8125rem; }
  h1 { margin: 0 0 1rem; font-size: clamp(2rem, 4vw, 3rem); line-height: 1.15; letter-spacing: -0.03em; max-width: 16ch; }
  .case-summary { margin: 0 0 1.5rem; color: var(--color-text-muted); font-size: 1.0625rem; max-width: 48rem; }
  .case-details { display: flex; flex-wrap: wrap; gap: 1.5rem 2.5rem; margin: 0; }
  .case-details dt { margin: 0 0 0.25rem; color: var(--color-text-muted); font-size: 0.8125rem; text-transform: uppercase; }
  .case-details dd { margin: 0; font-weight: 600; }
  .case-cover img { width: 100%; border-radius: var(--radius-lg); box-shadow: var(--shadow-lg); }
  .case-content { display: grid; gap: 2rem; max-width: 48rem; }
  .case-content h2 { margin: 0 0 0.75rem; font-size: 1.25rem; }
  .case-content p { margin: 0; color: var(--color-text-muted); }
  .gallery-section { background: white; padding-top: 0; }
  .gallery { display: grid; gap: 1.25rem; }
  .gallery img { width: 100%; border-radius: var(--radius-lg); border: 1px solid var(--color-border); }
</style>
