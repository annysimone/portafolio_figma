---
import Base from '../../layouts/Base.astro';
import { useTranslations } from '../../i18n/ui';

const lang = 'en';
const t = useTranslations(lang);
---

<Base title={`${t.contact.title} — Portfolio`} description={t.contact.subtitle} lang={lang} currentPath="/en/contact">
  <section class="section">
    <div class="container contact-grid">
      <div>
        <h1 class="section-title">{t.contact.title}</h1>
        <p class="section-subtitle">{t.contact.subtitle}</p>
        <div class="contact-links">
          <a href="mailto:hello@example.com">hello@example.com</a>
          <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        </div>
      </div>
      <form class="contact-form" action="https://formspree.io/f/xpwzgkqr" method="POST">
        <label>{t.contact.name}<input type="text" name="name" required autocomplete="name" /></label>
        <label>{t.contact.email}<input type="email" name="email" required autocomplete="email" /></label>
        <label>{t.contact.message}<textarea name="message" rows="6" required></textarea></label>
        <button type="submit" class="btn btn-primary">{t.contact.send}</button>
      </form>
    </div>
  </section>
</Base>

<style>
  .contact-grid { display: grid; gap: 2.5rem; align-items: start; }
  .contact-links { display: flex; flex-direction: column; gap: 0.5rem; }
  .contact-links a { color: var(--color-accent); font-weight: 600; }
  .contact-form {
    display: grid; gap: 1rem; padding: 1.5rem; background: white;
    border: 1px solid var(--color-border); border-radius: var(--radius-lg); box-shadow: var(--shadow);
  }
  label { display: grid; gap: 0.375rem; font-weight: 500; font-size: 0.9375rem; }
  input, textarea {
    width: 100%; padding: 0.75rem 0.875rem; border: 1px solid var(--color-border);
    border-radius: var(--radius); background: var(--color-bg);
  }
  input:focus, textarea:focus { outline: 2px solid var(--color-accent-soft); border-color: var(--color-accent); }
  @media (min-width: 900px) { .contact-grid { grid-template-columns: 1fr 1fr; } }
</style>
