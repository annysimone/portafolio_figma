---
import '../styles/global.css';
import type { Lang } from '../i18n/config';
import { defaultLang } from '../i18n/config';
import { alternateLangPath } from '../i18n/utils';
import { useTranslations } from '../i18n/ui';
import { contact, portfolioOgImage } from '../data/site';
import Navigation from '../components/portfolio/Navigation.astro';
import Footer from '../components/portfolio/Footer.astro';
import ThemeInit from '../components/ui/ThemeInit.astro';
import VercelAnalytics from '@vercel/analytics/astro';

interface Props {
  lang: Lang;
  title: string;
  description?: string;
  current?: 'home' | 'about';
  hideFooter?: boolean;
  ogImage?: string;
}

const {
  lang,
  title,
  description = 'Portafolio de Anny Mamani — Product Designer',
  current = 'home',
  hideFooter = false,
  ogImage = portfolioOgImage,
} = Astro.props;

const site = Astro.site ?? new URL('https://portafolio-figma-nu.vercel.app');
const canonical = new URL(Astro.url.pathname, site);
const altLang = lang === 'es' ? 'en' : 'es';
const altHref = new URL(alternateLangPath(Astro.url.pathname, altLang), site);
const ogImageUrl = new URL(ogImage, site).href;
const t = useTranslations(lang);

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Anny Mamani',
  jobTitle: 'Product Designer',
  url: site.href,
  email: contact.email,
  sameAs: [contact.linkedin, contact.behance],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Anny Mamani" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical.href} />
    <link rel="alternate" hreflang={lang} href={canonical.href} />
    <link rel="alternate" hreflang={altLang} href={altHref.href} />
    <link rel="alternate" hreflang="x-default" href={new URL(alternateLangPath(Astro.url.pathname, defaultLang), site).href} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Anny Mamani — Product Designer" />
    <meta property="og:locale" content={lang === 'es' ? 'es_PE' : 'en_US'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:secure_url" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Anny Mamani — Product Designer" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <ThemeInit />
  </head>
  <body>
    <a href="#main-content" class="skip-link">{t.a11y.skipToContent}</a>
    <div class="relative min-h-screen flex flex-col items-center px-4 sm:px-[50px] bg-[var(--color-bg)] text-[var(--color-text)]">
      <Navigation {lang} {current} />
      <div id="main-content" class="w-full">
        <slot />
      </div>
      {!hideFooter && <Footer lang={lang} />}
    </div>
    <VercelAnalytics />
  </body>
</html>
