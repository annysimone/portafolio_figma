---
import '../styles/global.css';
import Navigation from '../components/figma/Navigation.astro';
import Footer from '../components/figma/Footer.astro';

interface Props {
  title: string;
  description?: string;
  current?: 'home' | 'about';
  hideFooter?: boolean;
}

const { title, description = 'Portafolio de Anny Mamani — Product Designer', current = 'home', hideFooter = false } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-white text-black">
    <div class="relative min-h-screen flex flex-col items-center px-[50px]">
      <Navigation current={current} />
      <slot />
      {!hideFooter && <Footer />}
    </div>
  </body>
</html>
