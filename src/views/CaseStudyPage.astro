---
import type { Lang } from '../i18n/config';
import type { CaseStudy } from '../data/types';
import Portfolio from '../layouts/Portfolio.astro';
import CaseStudyView from '../components/portfolio/CaseStudyView.astro';
import { getProjectShareImage } from '../data/site';
import { pick } from '../i18n/utils';

interface Props {
  lang: Lang;
  study: CaseStudy;
}

const { lang, study } = Astro.props;
const ogImage = getProjectShareImage(study.slug) ?? study.gallery?.[0] ?? '/og-image.png';
---

<Portfolio
  lang={lang}
  title={pick(study.meta.title, lang)}
  description={pick(study.meta.description, lang)}
  ogImage={ogImage}
>
  <CaseStudyView lang={lang} study={study} />
</Portfolio>
