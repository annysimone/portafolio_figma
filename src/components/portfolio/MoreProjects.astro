---
import type { Lang } from '../../i18n/config';
import { getProjectPreview } from '../../data/site';
import { localizedPath, pick } from '../../i18n/utils';
import { useTranslations } from '../../i18n/ui';

interface Props {
  lang: Lang;
  slugs: string[];
}

const { lang, slugs } = Astro.props;
const t = useTranslations(lang);
const projects = slugs.map((slug) => getProjectPreview(slug)).filter(Boolean);
---

<section class="cs-more-projects border-t-4 border-[var(--color-border)] flex flex-col gap-12 py-[30px] w-full px-12 mt-16" aria-labelledby="more-projects-heading">
  <h2 id="more-projects-heading" class="font-manjari text-[var(--color-text-muted)] text-2xl tracking-[-1.08px]">
    {t.caseStudy.moreProjects}
  </h2>
  <div class="grid gap-12 md:grid-cols-2 w-full">
    {
      projects.map((project) => {
        if (!project) return null;
        const href = localizedPath(project.href, lang);
        const label = project.aboutLabel ? pick(project.aboutLabel, lang) : pick(project.title, lang);
        const title = pick(project.title, lang);
        const imageAlt = pick(project.imageAlt, lang);
        const previewImage = project.aboutImage ?? project.image;
        return (
          <article class="flex flex-col gap-6">
            <div class="flex flex-col gap-[19px]">
              <h3
                class="font-source-code font-medium text-base tracking-[-0.72px] underline m-0"
                style={`color: ${project.accent}`}
              >
                {label}
              </h3>
              <p
                class="font-manjari leading-[1.2] text-[clamp(28px,3vw,48px)] tracking-[-2.16px] m-0"
                style={`color: ${project.accent}`}
              >
                {title}
              </p>
              <a
                href={href}
                class="border flex h-8 items-center justify-center px-2.5 rounded font-source-code text-base tracking-[-0.72px] w-[70px] no-underline"
                style={`border-color: ${project.accent}; color: ${project.accent}`}
              >
                {t.home.view}
              </a>
            </div>
            <div class="aspect-square relative rounded shadow-md w-full overflow-hidden">
              <img
                alt={imageAlt}
                class="absolute inset-0 object-contain rounded size-full"
                src={previewImage}
                loading="lazy"
              />
            </div>
          </article>
        );
      })
    }
  </div>
</section>
