---
interface Props {
  current?: 'home' | 'about';
}

const { current = 'home' } = Astro.props;
const avatar = '/assets/original/avatar.png';
---

<nav class="absolute bg-gradient-to-r from-white to-white/50 flex items-center justify-between left-0 pb-12 pt-[30px] px-[50px] right-0 top-0 z-50">
  <a href="/" class="flex gap-5 items-center no-underline text-black">
    <div class="relative rounded-full shadow-md shrink-0 size-16 overflow-hidden">
      <img alt="Anny Mamani" class="absolute h-[129%] left-[-3.45%] max-w-none top-[-6.81%] w-[105%]" src={avatar} />
    </div>
    <span class="font-manjari text-2xl tracking-[-1.08px]">Anny Mamani</span>
  </a>
  <div class="flex gap-2.5 items-center font-source-code text-base tracking-[-0.72px]">
    {
      current === 'home' ? (
        <span class="text-[#ab0782]">Home</span>
      ) : (
        <a href="/" class="text-[#ab0782] underline">Home</a>
      )
    }
    {
      current === 'about' ? (
        <span class="text-black">About</span>
      ) : (
        <a href="/about" class="text-black underline">About</a>
      )
    }
  </div>
</nav>
