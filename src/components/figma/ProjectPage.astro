---
import Portfolio from '../../layouts/Portfolio.astro';

interface Props {
  title: string;
  description: string;
  image: string;
  alt: string;
}

const { title, description, image, alt } = Astro.props;
---

<Portfolio {title} {description} hideFooter>
  <main class="w-full max-w-[1600px] mx-auto pt-[100px]">
    <img src={image} alt={alt} class="w-full h-auto block" loading="eager" />
  </main>
</Portfolio>
