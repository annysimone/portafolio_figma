---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/ui';

interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const t = useTranslations(lang);
const prefix = lang === 'en' ? '/en' : '';

const links = [
  { href: `${prefix}/`, label: t.nav.home },
  { href: `${prefix}/about`, label: t.nav.about },
  { href: `${prefix}/work`, label: t.nav.work },
  { href: `${prefix}/contact`, label: t.nav.contact },
];

function isActive(href: string) {
  if (href === `${prefix}/` || href === '/') {
    return currentPath === href || currentPath === `${prefix}/` || currentPath === '/';
  }
  return currentPath.startsWith(href);
}

const otherLang = lang === 'es' ? 'en' : 'es';
const switchPath =
  lang === 'es'
    ? currentPath === '/'
      ? '/en/'
      : `/en${currentPath}`
    : currentPath.replace(/^\/en/, '') || '/';
---

<header class="header">
  <div class="container header-inner">
    <a href={`${prefix}/`} class="logo" aria-label="Portafolio home">
      <span class="logo-mark">A</span>
      <span class="logo-text">Portafolio</span>
    </a>

    <nav class="nav-desktop" aria-label="Main">
      {
        links.map((link) => (
          <a href={link.href} class:list={['nav-link', { active: isActive(link.href) }]}>
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="header-actions">
      <a href={switchPath} class="lang-switch" aria-label={`Switch to ${otherLang}`}>
        {otherLang.toUpperCase()}
      </a>
      <button class="menu-toggle" aria-expanded="false" aria-controls="mobile-menu" type="button">
        <span class="sr-only">Menu</span>
        <span class="bar"></span>
        <span class="bar"></span>
      </button>
    </div>
  </div>

  <nav id="mobile-menu" class="nav-mobile" aria-label="Mobile" hidden>
    <div class="container">
      {
        links.map((link) => (
          <a href={link.href} class="nav-mobile-link">
            {link.label}
          </a>
        ))
      }
    </div>
  </nav>
</header>

<script>
  const toggle = document.querySelector('.menu-toggle');
  const menu = document.querySelector('#mobile-menu');

  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    menu?.toggleAttribute('hidden');
    toggle.classList.toggle('open');
  });
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgb(255 255 255 / 92%);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: var(--header-height);
    gap: 1rem;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-weight: 700;
  }

  .logo-mark {
    display: grid;
    place-items: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.625rem;
    background: var(--color-accent);
    color: white;
    font-size: 1rem;
  }

  .logo-text {
    font-size: 1.0625rem;
    letter-spacing: -0.02em;
  }

  .nav-desktop {
    display: none;
    align-items: center;
    gap: 2rem;
  }

  .nav-link {
    color: var(--color-text-muted);
    font-weight: 500;
    font-size: 0.9375rem;
    transition: color 0.15s ease;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--color-accent);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .lang-switch {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.5rem;
    padding: 0.375rem 0.625rem;
    border-radius: 999px;
    background: var(--color-accent-soft);
    color: var(--color-accent);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  .menu-toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.35rem;
    width: 2.5rem;
    height: 2.5rem;
    padding: 0;
    border: 1px solid var(--color-border);
    border-radius: 0.625rem;
    background: white;
    cursor: pointer;
  }

  .bar {
    display: block;
    width: 1.125rem;
    height: 2px;
    margin-inline: auto;
    background: var(--color-text);
    transition: transform 0.2s ease;
  }

  .menu-toggle.open .bar:first-child {
    transform: translateY(4px) rotate(45deg);
  }

  .menu-toggle.open .bar:last-child {
    transform: translateY(-4px) rotate(-45deg);
  }

  .nav-mobile {
    border-top: 1px solid var(--color-border);
    background: white;
    padding-block: 1rem;
  }

  .nav-mobile-link {
    display: block;
    padding: 0.75rem 0;
    font-weight: 500;
    color: var(--color-text);
    border-bottom: 1px solid var(--color-border);
  }

  @media (min-width: 768px) {
    .nav-desktop {
      display: flex;
    }

    .menu-toggle {
      display: none;
    }

    .nav-mobile {
      display: none !important;
    }
  }
</style>
