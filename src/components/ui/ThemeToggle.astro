---
import type { Lang } from '../../i18n/config';
import { useTranslations } from '../../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<button
  type="button"
  id="theme-toggle"
  class="border border-[var(--color-border)] rounded px-2.5 h-8 font-source-code text-sm tracking-[-0.72px] bg-transparent cursor-pointer text-[var(--color-text)] hover:opacity-80 transition-opacity"
  aria-label={t.nav.themeDark}
  data-label-light={t.nav.themeLight}
  data-label-dark={t.nav.themeDark}
>
  <span class="theme-icon-light" aria-hidden="true">☀</span>
  <span class="theme-icon-dark hidden" aria-hidden="true">☾</span>
</button>

<script>
  function syncThemeToggle() {
    const root = document.documentElement;
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;

    const isDark = root.getAttribute('data-theme') === 'dark';
    btn.querySelector('.theme-icon-light')?.classList.toggle('hidden', isDark);
    btn.querySelector('.theme-icon-dark')?.classList.toggle('hidden', !isDark);
    btn.setAttribute(
      'aria-label',
      isDark ? btn.dataset.labelLight ?? 'Light mode' : btn.dataset.labelDark ?? 'Dark mode',
    );
  }

  function toggleTheme() {
    const root = document.documentElement;
    const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    root.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    syncThemeToggle();
  }

  document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);
  syncThemeToggle();
</script>

<style>
  .hidden {
    display: none;
  }
</style>
