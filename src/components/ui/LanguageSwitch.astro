---
import type { Lang } from '../../i18n/config';
import { langLabels, locales } from '../../i18n/config';
import { alternateLangPath } from '../../i18n/utils';
import { useTranslations } from '../../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const pathname = Astro.url.pathname;
---

<nav aria-label={t.nav.langSwitch} class="flex gap-1 font-source-code text-sm tracking-[-0.72px]">
  {
    locales.map((locale) => {
      const isActive = locale === lang;
      const href = alternateLangPath(pathname, locale);
      return isActive ? (
        <span class="text-[var(--color-accent-pink)] px-1" aria-current="true">
          {langLabels[locale]}
        </span>
      ) : (
        <a
          href={href}
          class="text-[var(--color-text-muted)] underline px-1 hover:text-[var(--color-text)]"
          hreflang={locale}
          lang={locale}
        >
          {langLabels[locale]}
        </a>
      );
    })
  }
</nav>
