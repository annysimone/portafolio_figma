---
import type { Project } from '../data/projects';
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/ui';

interface Props {
  project: Project;
  lang: Lang;
}

const { project, lang } = Astro.props;
const t = useTranslations(lang);
const prefix = lang === 'en' ? '/en' : '';
---

<article class="card">
  <a href={`${prefix}/projects/${project.slug}`} class="card-link">
    <div class="card-image">
      <img src={project.cover} alt={project.title[lang]} loading="lazy" />
    </div>
    <div class="card-body">
      <p class="card-meta">{project.client} · {project.year}</p>
      <h3 class="card-title">{project.title[lang]}</h3>
      <p class="card-summary">{project.summary[lang]}</p>
      <span class="card-cta">{t.featured.viewCase} →</span>
    </div>
  </a>
</article>

<style>
  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .card-link {
    display: block;
    height: 100%;
  }

  .card-image {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--color-hero-bg);
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-body {
    padding: 1.25rem 1.25rem 1.5rem;
  }

  .card-meta {
    margin: 0 0 0.5rem;
    color: var(--color-accent);
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .card-title {
    margin: 0 0 0.625rem;
    font-size: 1.125rem;
    line-height: 1.35;
  }

  .card-summary {
    margin: 0 0 1rem;
    color: var(--color-text-muted);
    font-size: 0.9375rem;
  }

  .card-cta {
    color: var(--color-accent);
    font-weight: 600;
    font-size: 0.875rem;
  }
</style>
